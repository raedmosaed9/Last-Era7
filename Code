<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Last Era RP</title>
  <link rel="icon" type="image/png" href="Logo/LE.png">
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0c0c0f;
      --surface: #111115;
      --card-bg: #16161a;
      --border: rgba(255,255,255,0.07);
      --gold: #d4a843;
      --gold2: #c49535;
      --text: #e8e3db;
      --muted: #888580;
      --nav-h: 68px;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Cairo', sans-serif;
      background: var(--bg);
      color: var(--text);
      overflow-x: hidden;
      position: relative;
    }

    /* ═══════════════ BACKGROUND LAYERS ═══════════════ */
    .bg-layer {
      position: absolute;
      top: 0; left: 0; right: 0;
      min-height: 100%;
      z-index: 0;
      pointer-events: none;
      background:
        radial-gradient(ellipse 60% 45% at 90% 100%, rgba(196,149,53,0.32) 0%, transparent 60%),
        radial-gradient(ellipse 50% 45% at 5%  100%, rgba(212,168,67,0.26) 0%, transparent 60%),
        radial-gradient(ellipse 70% 35% at 50% 100%, rgba(212,168,67,0.18) 0%, transparent 55%),
        var(--bg);
    }

    /* Navbar flips to LTR when English */
    html[lang="en"] .navbar {
      direction: ltr;
      grid-template-columns: auto 1fr auto;
    }
    html[lang="en"] .navbar-logo { grid-column: 1; justify-self: start; }
    html[lang="en"] .navbar-links { grid-column: 2; direction: ltr; flex-direction: row; }
    html[lang="en"] .navbar-cta   { grid-column: 3; justify-self: end; }

    /* Arabic navbar — logo right, links center, cta left */
    html[lang="ar"] .navbar {
      direction: rtl;
      grid-template-columns: auto 1fr auto;
    }
    html[lang="ar"] .navbar-logo { grid-column: 1; justify-self: start; }
    html[lang="ar"] .navbar-links { grid-column: 2; direction: rtl; flex-direction: row; }
    html[lang="ar"] .navbar-cta   { grid-column: 3; justify-self: end; }

    a { text-decoration: none; }

    /* ═══════════════ NAV ═══════════════ */
    .navbar {
      position: fixed;
      top: 12px; left: 50%; right: auto;
      transform: translateX(-50%);
      width: calc(100% - 48px);
      max-width: 1200px;
      height: var(--nav-h);
      z-index: 999;
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      padding: 0 20px;
      background: rgba(18,18,22,0.92);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(212,168,67,0.35);
      border-radius: 16px;
      gap: 16px;
    }

    .navbar-logo {
      grid-column: 1;
      display: flex;
      align-items: center;
    }

    .navbar-logo img {
      height: 72px;
      width: auto;
      display: block;
      filter: drop-shadow(0 0 8px rgba(212,168,67,0.25)) drop-shadow(0 0 22px rgba(212,168,67,0.13));
    }

    .navbar-logo span { color: var(--gold); }

    .navbar-links {
      grid-column: 2;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.3rem;
      list-style: none;
      margin-top: -8px;
    }

    .navbar-links a {
      color: var(--muted);
      font-size: 0.88rem;
      font-weight: 600;
      transition: color 0.25s, background 0.25s, box-shadow 0.25s, text-shadow 0.25s;
      position: relative;
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 7px 14px;
      border-radius: 8px;
      white-space: nowrap;
    }

    .navbar-links a:hover {
      color: var(--gold);
      background: rgba(212, 168, 67, 0.10);
      box-shadow:
        0 0 10px rgba(212, 168, 67, 0.15),
        inset 0 0 10px rgba(212, 168, 67, 0.05);
      text-shadow: 0 0 8px rgba(212, 168, 67, 0.45);
    }

    .navbar-links a.active {
      color: #0c0c0f;
      background: var(--gold);
      font-weight: 700;
      box-shadow: 0 0 14px rgba(212, 168, 67, 0.4);
    }

    .navbar-links a::after { display: none; }

    /* ═══════════════ PAGES (SPA-style view switching) ═══════════════ */
    .page { display: none; position: relative; z-index: 1; }
    .page.active {
      display: block;
      animation: fadeUp 0.35s ease;
    }

    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(22px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .navbar-cta {
      grid-column: 3;
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 8px;
      margin-top: -8px;
    }

    .navbar-cta .btn {
      padding: 9px 20px;
      font-size: 0.88rem;
      border-radius: 8px;
      white-space: nowrap;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    /* ═══════════════ HERO ═══════════════ */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: calc(var(--nav-h) + 60px) 5% 80px;
      overflow: hidden;
    }

    /* Video background */
    .video-bg {
      position: absolute;
      inset: 0;
      width: 100%; height: 100%;
      overflow: hidden;
      z-index: 0;
      pointer-events: none;
    }

    .video-bg video {
      position: absolute;
      top: 50%; left: 50%;
      width: 100%; height: 100%;
      transform: translate(-50%, -50%);
      object-fit: cover;
      opacity: 0.35;
      filter: brightness(0.85) saturate(1.1);
      pointer-events: none;
    }

    .hero-veil {
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom,
        rgba(12,12,15,0.3) 0%,
        rgba(12,12,15,0.1) 40%,
        rgba(12,12,15,0.7) 80%,
        rgba(12,12,15,1) 100%);
    }

    .hero-content { position: relative; z-index: 2; max-width: 820px; }

    .hero-eyebrow {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--gold);
      border: 1px solid rgba(212,168,67,0.35);
      border-radius: 100px;
      padding: 6px 20px;
      margin-bottom: 30px;
    }

    .hero h1 {
      font-size: clamp(2.6rem, 6.5vw, 5.2rem);
      font-weight: 900;
      color: #fff;
      line-height: 1.1;
      margin-bottom: 22px;
      text-shadow:
        0 0 25px rgba(255,255,255,0.4),
        0 0 70px rgba(255,255,255,0.15),
        0 0 120px rgba(255,255,255,0.08);
    }

    .hero h1 .gold {
      color: var(--gold);
      text-shadow:
        0 0 20px rgba(212,168,67,0.5),
        0 0 50px rgba(212,168,67,0.3),
        0 0 100px rgba(212,168,67,0.15),
        0 0 160px rgba(212,168,67,0.08);
    }

    .hero-desc {
      font-size: 1.05rem;
      color: var(--muted);
      line-height: 1.85;
      max-width: 580px;
      margin: 0 auto 42px;
    }

    .hero-btns {
      display: flex;
      gap: 14px;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* ── Buttons ── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 13px 30px;
      border-radius: 8px;
      font-size: 0.95rem;
      font-weight: 700;
      font-family: 'Cairo', sans-serif;
      cursor: pointer;
      transition: transform 0.15s, box-shadow 0.15s, opacity 0.15s;
      border: none;
    }

    .btn:hover { transform: translateY(-2px); }

    .btn-primary {
      background: var(--gold);
      color: #0c0c0f;
      box-shadow: 0 4px 20px rgba(212,168,67,0.3);
    }

    .btn-primary:hover {
      background: var(--gold2);
      box-shadow: 0 6px 28px rgba(212,168,67,0.45);
    }

    .btn-ghost {
      background: transparent;
      color: var(--text);
      border: 1px solid rgba(255,255,255,0.15);
    }

    .btn-ghost:hover {
      border-color: rgba(255,255,255,0.3);
      background: rgba(255,255,255,0.05);
    }

    /* ── Stats ── */
    .hero-stats {
      position: relative;
      z-index: 2;
      display: flex;
      gap: 60px;
      justify-content: center;
      margin-top: 72px;
      flex-wrap: wrap;
    }

    .stat { text-align: center; }

    .stat-num {
      font-size: 2.4rem;
      font-weight: 900;
      color: var(--gold);
      line-height: 1;
    }

    .stat-lbl {
      font-size: 0.82rem;
      color: var(--muted);
      margin-top: 5px;
      letter-spacing: 0.04em;
    }

    /* ═══════════════ ABOUT ═══════════════ */
    .about-section {
      padding: 110px 6%;
      max-width: 1280px;
      margin: 0 auto;
    }

    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 90px;
      align-items: center;
    }

    .about-tag {
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 14px;
    }

    .about-title {
      font-size: clamp(1.8rem, 3.5vw, 2.7rem);
      font-weight: 900;
      color: #fff;
      line-height: 1.2;
      margin-bottom: 10px;
    }

    .about-line {
      width: 48px;
      height: 2px;
      background: var(--gold);
      margin: 18px 0 24px;
    }

    .about-text {
      color: var(--muted);
      font-size: 1rem;
      line-height: 1.9;
    }

    .about-text + .about-text { margin-top: 16px; }

    .about-img-wrap {
      position: relative;
    }

    .about-img {
      width: 100%;
      border-radius: 14px;
      border: 1px solid var(--border);
      object-fit: cover;
      aspect-ratio: 4/3;
      display: block;
    }

    .about-img-glow {
      position: absolute;
      inset: -1px;
      border-radius: 15px;
      background: linear-gradient(135deg, rgba(212,168,67,0.15), transparent 60%);
      pointer-events: none;
    }

    /* ═══════════════ CARDS ═══════════════ */
    .cards-section {
      background: var(--surface);
      padding: 100px 6%;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      direction: ltr;
    }

    .cards-inner { max-width: 1280px; margin: 0 auto; }

    .cards-hdr {
      text-align: center;
      margin-bottom: 60px;
    }

    .cards-hdr .section-tag {
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 12px;
    }

    .cards-hdr h2 {
      font-size: clamp(1.7rem, 3vw, 2.5rem);
      font-weight: 900;
      color: #fff;
    }

    .cards-hdr .sep {
      width: 40px; height: 2px;
      background: var(--gold);
      margin: 16px auto 0;
    }

    .cards-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 22px;
    }

    .card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 36px 30px;
      transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
    }

    .card:hover {
      border-color: rgba(212,168,67,0.4);
      transform: translateY(-5px);
      box-shadow: 0 16px 40px rgba(0,0,0,0.4);
    }

    .card-icon {
      width: 50px; height: 50px;
      border-radius: 12px;
      background: rgba(212,168,67,0.1);
      border: 1px solid rgba(212,168,67,0.2);
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 22px;
    }

    .card-icon svg {
      width: 22px; height: 22px;
      fill: none; stroke: var(--gold); stroke-width: 1.8;
      stroke-linecap: round; stroke-linejoin: round;
    }

    .card h3 {
      font-size: 1.12rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 12px;
    }

    .card p {
      font-size: 0.91rem;
      color: var(--muted);
      line-height: 1.75;
    }

    .card-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-top: 24px;
      padding: 10px 22px;
      border-radius: 7px;
      font-size: 0.88rem;
      font-weight: 700;
      font-family: 'Cairo', sans-serif;
      background: rgba(212,168,67,0.1);
      color: var(--gold);
      border: 1px solid rgba(212,168,67,0.25);
      cursor: pointer;
      transition: background 0.2s, border-color 0.2s;
    }

    .card-btn:hover {
      background: rgba(212,168,67,0.18);
      border-color: rgba(212,168,67,0.5);
    }

    /* ═══════════════ CREATORS HERO ═══════════════ */
    .creators-hero {
      position: relative;
      padding: 100px 6% 50px;
      max-width: 1280px;
      margin: 0 auto;
    }

    .creators-hero-inner {
      display: flex;
      justify-content: center;
    }

    .creators-text {
      text-align: center;
      max-width: 760px;
    }

    .creators-tag {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      border: 1px solid rgba(212,168,67,0.35);
      border-radius: 100px;
      padding: 7px 22px;
      margin-bottom: 28px;
    }

    .creators-text h1 {
      font-size: clamp(2.3rem, 5vw, 4rem);
      font-weight: 900;
      color: #fff;
      line-height: 1.18;
      margin-bottom: 22px;
      text-shadow:
        0 0 25px rgba(255,255,255,0.25),
        0 0 70px rgba(255,255,255,0.1);
    }

    .creators-text h1 .gold {
      color: var(--gold);
      text-shadow:
        0 0 20px rgba(212,168,67,0.5),
        0 0 60px rgba(212,168,67,0.25);
    }

    .creators-desc {
      color: var(--muted);
      font-size: 1rem;
      line-height: 1.9;
      max-width: 540px;
      margin: 0 auto 32px;
    }

    .creators-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-bottom: 36px;
      justify-content: center;
    }

    .creator-badge {
      display: flex;
      align-items: center;
      gap: 7px;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--muted);
      border: 1px solid var(--border);
      border-radius: 100px;
      padding: 10px 20px;
      background: rgba(255,255,255,0.02);
    }

    .creator-badge .gold { color: var(--gold); font-weight: 800; }

    .creators-btns {
      display: flex;
      gap: 14px;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* ═══════════════ FILTER TABS ═══════════════ */
    .filter-section {
      max-width: 1280px;
      margin: 0 auto;
      padding: 30px 6% 60px;
    }

    .filter-tabs {
      display: flex;
      justify-content: center;
      gap: 14px;
      flex-wrap: wrap;
    }

    .filter-btn {
      display: flex;
      align-items: center;
      gap: 8px;
      background: var(--card-bg);
      border: 1px solid var(--border);
      color: var(--muted);
      font-family: 'Cairo', sans-serif;
      font-size: 0.92rem;
      font-weight: 700;
      padding: 14px 30px;
      border-radius: 12px;
      cursor: pointer;
      transition: border-color 0.2s, color 0.2s, background 0.2s, box-shadow 0.2s;
    }

    .filter-btn:hover {
      border-color: rgba(212,168,67,0.35);
      color: var(--text);
    }

    .filter-btn.active {
      background: var(--gold);
      color: #0c0c0f;
      border-color: var(--gold);
      box-shadow: 0 6px 22px rgba(212,168,67,0.3);
    }

    /* ═══════════════ KICK STREAMERS ═══════════════ */
    .streamers-section {
      padding: 0 6% 100px;
      max-width: 1280px;
      margin: 0 auto;
    }

    .streamers-hdr {
      text-align: center;
      margin-bottom: 60px;
    }

    .streamers-hdr .section-tag {
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 12px;
    }

    .streamers-hdr h2 {
      font-size: clamp(1.7rem, 3vw, 2.5rem);
      font-weight: 900;
      color: #fff;
    }

    .streamers-hdr .sep {
      width: 40px; height: 2px;
      background: var(--gold);
      margin: 16px auto 0;
    }

    .streamers-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 22px;
    }

    .streamer-card {
      position: relative;
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 32px 24px;
      text-align: center;
      transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
    }

    .streamer-card:hover {
      transform: translateY(-5px);
    }

    /* Red glow + border when the streamer is LIVE (toggled via JS) */
    .streamer-card.is-live {
      border-color: rgba(220,38,38,0.55);
      box-shadow: 0 0 0 1px rgba(220,38,38,0.15), 0 16px 45px rgba(220,38,38,0.25);
      animation: live-pulse 2.2s ease-in-out infinite alternate;
    }

    @keyframes live-pulse {
      from { box-shadow: 0 0 0 1px rgba(220,38,38,0.15), 0 10px 30px rgba(220,38,38,0.18); }
      to   { box-shadow: 0 0 0 1px rgba(220,38,38,0.35), 0 18px 50px rgba(220,38,38,0.4); }
    }

    .streamer-avatar-wrap {
      position: relative;
      width: 92px; height: 92px;
      margin: 0 auto 18px;
    }

    .streamer-avatar {
      width: 92px; height: 92px;
      border-radius: 50%;
      object-fit: cover;
      display: block;
      border: 2px solid var(--border);
      transition: border-color 0.25s;
    }

    .streamer-card.is-live .streamer-avatar {
      border-color: #dc2626;
    }

    /* Red LIVE badge - hidden by default, shown via JS when the streamer goes live */
    .live-badge {
      position: absolute;
      top: -4px; left: -4px;
      display: none;
      align-items: center;
      gap: 4px;
      background: #dc2626;
      color: #fff;
      font-size: 0.62rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 3px 9px;
      border-radius: 100px;
      box-shadow: 0 0 14px rgba(220,38,38,0.65);
    }

    .live-badge::before {
      content: '';
      width: 6px; height: 6px;
      border-radius: 50%;
      background: #fff;
      animation: live-dot 1.3s infinite;
    }

    @keyframes live-dot {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.25; }
    }

    .streamer-card.is-live .live-badge {
      display: flex;
    }

    .streamer-name {
      font-size: 1.05rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 6px;
    }

    .streamer-followers {
      font-size: 0.85rem;
      color: var(--muted);
      margin-bottom: 14px;
    }

    .streamer-status {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--muted);
      margin: 0 auto 20px;
      padding: 5px 16px;
      border-radius: 100px;
      border: 1px solid var(--border);
    }

    .status-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--muted);
      transition: background 0.25s, box-shadow 0.25s;
    }

    .streamer-card.is-live .streamer-status {
      color: #ff6b6b;
      border-color: rgba(220,38,38,0.3);
      background: rgba(220,38,38,0.08);
    }

    .streamer-card.is-live .status-dot {
      background: #dc2626;
      box-shadow: 0 0 8px rgba(220,38,38,0.85);
    }

    .streamer-watch-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      padding: 11px 20px;
      border-radius: 8px;
      font-size: 0.9rem;
      font-weight: 700;
      font-family: 'Cairo', sans-serif;
      background: rgba(255,255,255,0.05);
      color: var(--muted);
      border: 1px solid var(--border);
      cursor: not-allowed;
      pointer-events: none;
      opacity: 0.55;
      transition: background 0.2s, border-color 0.2s, color 0.2s, opacity 0.2s, transform 0.15s;
    }

    /* Watch button becomes active/clickable only when the streamer is LIVE */
    .streamer-card.is-live .streamer-watch-btn {
      background: #dc2626;
      color: #fff;
      border-color: #dc2626;
      cursor: pointer;
      pointer-events: auto;
      opacity: 1;
      box-shadow: 0 4px 18px rgba(220,38,38,0.35);
    }

    .streamer-card.is-live .streamer-watch-btn:hover {
      background: #b91c1c;
      transform: translateY(-2px);
    }

    .no-results {
      text-align: center;
      color: var(--muted);
